{
    "ipc": true,
    "position": "top",
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": [],
    "modules-right": ["wireplumber", "backlight", "battery", "network", "cpu", "memory", "clock", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },
    "sway/mode": {
        "format": "{}",
    },
    "sway/window": {
        "format": "{}",
        "icon": false,
    },
    "clock": {
        "interval": 2,
        "format": "󰥔 {:%d %A %H:%M}", // alternative clock icon
        "tooltip": false
    },
    "memory": {
        "interval": 2,
        "format": "󰘚 {percentage:0>2}%" // alternative memory icon
    },
    "network": {
        "interval": 2,
        "tooltip": false,
        "format-wifi": "󰤨 {essid} {signalStrength}%", // alternative wifi icon
        "format-ethernet": "󰈁 {ipaddr}" // alternative ethernet icon
    },
    "battery": {
        "interval": 2,
        "tooltip": false,
        "format": "󰁹 {capacity}%", // alternative battery icon
        "states": {
            "warning": 30,
            "critical": 15
        },
    },
    "backlight": {
        "format": "󰃞 {percent}%" // alternative brightness icon
    },
    "wireplumber": {
        "format": "󰕾 {volume}%", // alternative volume icon
        "format-muted": "󰖁 {volume}%",
        "format-bluetooth": "󰂯 {desc} {volume}%",
        "tooltip": false
    },
    "cpu": {
        "interval": 2,
        "format": "󰍛 {usage:0>2}%" // alternative cpu icon
    },
    "tray": {
        "icon-size": 14,
        "spacing": 8
    }
}
